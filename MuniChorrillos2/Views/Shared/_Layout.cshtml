<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MuniChorrillos2</title>
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MuniChorrillos2.styles.css" asp-append-version="true" />
    
</head>
<body>
    <header>
        <section class="header__info">
            <p>Si nececitas ayuda comunicate con InkaCode Perú al <span class="phone_number">946980952</span></p>
        </section>

        <section class="container-navbar">
            <nav class="navbar container">
                <a href="#" class="navbar__logo">
                    <img src="Images/logoMuni.png" alt="logo municipal" />
                    <span></span>
                </a>
                <div class="navbar__nav"> 
                     <ul class="nav__list">
                        <li class="nav__link">
                            <a asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav__link">
                            <a asp-controller="Areas" asp-action="Index">Areas</a>
                        </li>
                        <li class="nav__link">
                            <a asp-controller="Personals" asp-action="Index">Empleados</a>
                        </li>
                        <li class="nav__link">
                            <a asp-controller="Multas" asp-action="Index">Multas</a>
                        </li>
                        <li class="nav__link">
                            <a asp-controller="Infraccions" asp-action="Index">Infracciones</a>
                        </li>
                        <li class="nav__link">
                            <a asp-controller="Horarios" asp-action="Index">Horarios</a>
                        </li>
                        <li class="nav__link">
                            <a asp-controller="Vmunicipals" asp-action="Index">Municipal</a>
                        </li>
                        <li class="nav__link">
                            <a asp-controller="Fiscalizacion" asp-action="Index">Fiscalización</a>
                        </li>
                        <li class="nav__link">
                            <a asp-controller="Infractores" asp-action="Index">Infractores</a>
                        </li>
                        <li class="nav__link">
                            <a asp-controller="Home" asp-action="Logout">Salir</a>
                        </li>
                        <div class="dropdown">
                            <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Dropdown button
                            </button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="#">Action</a></li>
                                <li><a class="dropdown-item" href="#">Another action</a></li>
                                <li><a class="dropdown-item" href="#">Something else here</a></li>
                            </ul>
                        </div>

                    </ul>    

                     <button class="navbar__toogle-btn">
                         <img src="images/3puntos.png" alt="desplegable" />
                     </button>
                     <div class="navbar__mobile-menu">
                        <ul class="nav__list-mobile">
                            <li class="nav__link-mobile">
                               
                                <a href="Personals/index">empleados</a>
                            </li>
                          
                        </ul>
                     </div>
                </div>
            </nav>
        </section>

    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2024 - MuniChorrillos2 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Equipo</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
