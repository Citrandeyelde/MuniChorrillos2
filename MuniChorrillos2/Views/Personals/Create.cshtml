@using System.Text
@using System.Security.Cryptography
@model MuniChorrillos2.Models.Personal

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Personal</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" autocomplete="new-password">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="IdEmpleado" class="control-label"></label>
                <select asp-for="IdEmpleado" class ="form-control" asp-items="ViewBag.IdEmpleado"></select>
            </div>
            <div class="form-group">
                <label asp-for="IdArea" class="control-label"></label>
                <select asp-for="IdArea" class ="form-control" asp-items="ViewBag.IdArea"></select>
            </div>
            <div class="form-group">
                <label asp-for="UsuarioAcceso" class="control-label"></label>
                <input asp-for="UsuarioAcceso" type="text" class="form-control" />
                <span asp-validation-for="UsuarioAcceso" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Contraseña"  class="control-label"></label>
                <input asp-for="Contraseña" type="password" class="form-control" />
                <span asp-validation-for="Contraseña" class="text-danger"></span>
                
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
